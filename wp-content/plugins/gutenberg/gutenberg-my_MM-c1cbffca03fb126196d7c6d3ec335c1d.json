03c\u102c\u1038\u101c\u102f\u1015\u103a\u1000\u103d\u1000\u103a\u1021\u1019\u103b\u102d\u102f\u1038\u1021\u1005\u102c\u1038\u1019\u103b\u102c\u1038\u1000\u102d\u102f \u1005\u1019\u103a\u1038\u101e\u1015\u103a\u1011\u100a\u1037\u103a\u101e\u103d\u1004\u103a\u1038\u1015\u103c\u102e\u1038 \u101e\u1004\u1037\u103a\u101d\u1018\u103a\u1006\u102d\u102f\u1012\u103a\u1010\u103d\u1004\u103a \u1019\u100a\u103a\u101e\u102d\u102f\u1037\u1019\u103c\u1004\u103a\u1010\u103d\u1031\u1037\u101b\u1019\u100a\u103a\u1000\u102d\u102f \u101c\u1031\u1037\u101c\u102c\u1000\u103c\u100a\u1037\u103a\u101b\u103e\u102f\u101c\u102d\u102f\u1000\u103a\u1015\u102b\u104b"],"Welcome to block Widgets":["\u101c\u102f\u1015\u103a\u1000\u103d\u1000\u103a\u101d\u1005\u103a\u1002\u103b\u1010\u103a\u1019\u103b\u102c\u1038 (Block Widgets) \u1019\u103e \u1000\u103c\u102d\u102f\u1006\u102d\u102f\u1015\u102b\u101e\u100a\u103a"],"Contain text cursor inside block deactivated":["\u101c\u102f\u1015\u103a\u1000\u103d\u1000\u103a\u1021\u1010\u103d\u1004\u103a\u1038 \u1005\u102c\u101e\u102c\u1038\u1000\u102c\u1006\u102c \u1000\u1014\u1037\u103a\u101e\u1010\u103a\u1011\u102c\u1038\u1019\u103e\u102f\u1000\u102d\u102f \u1015\u102d\u1010\u103a\u1011\u102c\u1038\u101e\u100a\u103a"],"Contain text cursor inside block activated":["\u101c\u102f\u1015\u103a\u1000\u103d\u1000\u103a\u1021\u1010\u103d\u1004\u103a\u1038 \u1005\u102c\u101e\u102c\u1038\u1000\u102c\u1006\u102c \u1000\u1014\u1037\u103a\u101e\u1010\u103a\u1011\u102c\u1038\u1019\u103e\u102f\u1000\u102d\u102f \u1016\u103d\u1004\u1037\u103a\u1011\u102c\u1038\u101e\u100a\u103a"],"Close inserter":["\u1011\u100a\u1037\u103a\u101e\u103d\u1004\u103a\u1038\u1000\u102d\u101b\u102d\u101a\u102c \u1015\u102d\u1010\u103a\u101b\u1014\u103a"],"Customizing":["\u1005\u102d\u1010\u103a\u1000\u103c\u102d\u102f\u1000\u103a\u1015\u103c\u1004\u103a\u1006\u1004\u103a\u1014\u1031\u101e\u100a\u103a"],"Contain text cursor inside block":["\u1005\u102c\u101e\u102c\u1038\u1000\u102c\u1006\u102c\u1000\
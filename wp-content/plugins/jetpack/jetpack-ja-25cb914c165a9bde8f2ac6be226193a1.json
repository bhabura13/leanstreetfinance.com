c4\u306b\u4e00\u81f4: \u4e00\u81f4\u3057\u305f\u30c6\u30ad\u30b9\u30c8\u3092\u793a\u3059\u77ed\u3044\u629c\u7c8b\u3092\u542b\u3080\u3001\u904e\u53bb\u306e\u6295\u7a3f\u3002"],"A. Writer, B. Editor":["A. \u30e9\u30a4\u30bf\u30fc\u3001B. \u30a8\u30c7\u30a3\u30bf\u30fc"],"Matches content: a second excerpt demonstrating how content highlights appear in results.":["\u30b3\u30f3\u30c6\u30f3\u30c4\u306b\u4e00\u81f4: \u7d50\u679c\u306b\u30b3\u30f3\u30c6\u30f3\u30c4\u306e\u30cf\u30a4\u30e9\u30a4\u30c8\u304c\u3069\u306e\u3088\u3046\u306b\u8868\u793a\u3055\u308c\u308b\u304b\u3092\u793a\u30592\u756a\u76ee\u306e\u629c\u7c8b\u3002"],"Sample Author":["\u30b5\u30f3\u30d7\u30eb\u6295\u7a3f\u8005"],"Matches content: this snippet shows the relevant passage that matched your search query.":["\u30b3\u30f3\u30c6\u30f3\u30c4\u306b\u4e00\u81f4: \u3053\u306e\u30b9\u30cb\u30da\u30c3\u30c8\u306f\u3001\u691c\u7d22\u30af\u30a8\u30ea\u30fc\u306b\u4e00\u81f4\u3057\u305f\u95a2\u9023\u3059\u308b\u6587\u7ae0\u3092\u8868\u793a\u3057\u307e\u3059\u3002"],"Hide filter panel":["\u30d5\u30a3\u30eb\u30bf\u30fc\u30d1\u30cd\u30eb\u3092\u975e\u8868\u793a"],"Show filter panel":["\u30d5\u30a3\u30eb\u30bf\u30fc\u30d1\u30cd\u30eb\u3092\u8868\u793a"],"Heading shown above the options. Leave empty for the default.":["\u30aa\u30d7\u30b7\u30e7\u30f3\u306e\u4e0a\u306b\u8868\u793a\u3055\u308c\u308b\u898b\u51fa\u3057\u3002 \u30c7\u30d5\u30a9\u30eb\u30c8\u3067\u306f\u7a7a\u306e\u307e\u307e\u306b\u3057\u307e\u3059\u3002"],"In stock":["\u5728\u5eab\u3042\u308a"],"Hide rows you don\u2019t want shoppers to pick. At least one row must stay visible.":["\u8cfc\u5165\u8005\u306b\u9078\u629e\u3055\u305b\u305f\u304f\u306a\u3044\u884c\u3092\u975e\u8868\u793a\u306b\u3057\u307e\u3059\u3002 \u5c11\u306a\u304f\u3068\u30821\u884c\u306f\u8868\u793a\u3055\u308c\u305f\u307e\u307e\u306b\u3059\u308b\u5fc5\u8981\u304c\u3042\u308a\u307e\u3059\u3002"],"Visible rows":["\u8868\u793a\u3059\u308b\u884c\u6570"],"Heading shown above the star rows. Leave empty for the default.":["\u661f\u306e\u884c\u306e\u4e0a\u306b\u8868\u793a\u3055\u308c\u308b\u898b\u51fa\u3057\u3002 \u30c7\u30d5\u30a9\u30eb\u30c8\u3067\u306f\u7a7a\u306e\u307e\u307e\u306b\u3057\u307e\u3059\u3002"],"Slider granularity.":["\u30b9\u30e9\u30a4\u30c0\u30fc\u306e\u76ee\u76db\u308a\u3002"],"Maximum":["\u6700\u9ad8\u5024"],"Minimum":["\u6700\u5c0f\u5024"],"Minimum must be less than maximum for the slider to render correctly.":["\u30b9\u30e9\u30a4\u30c0\u30fc\u304c\u6b63\u3057\u304f\u30ec\u30f3\u30c0\u30ea\u30f3\u30b0\u3055\u308c\u308b\u3088\u3046\u306b\u3059\u308b\u306b\u306f\u3001\u6700\u5c0f\u5024\u3092\u6700\u5927\u5024\u3088\u308a\u5c0f\u3055\u304f\u3059\u308b\u5fc5\u8981\u304c\u3042\u308a\u307e\u3059\u3002"],"When enabled, the slider bounds match the store\u2019s actual minimum and maximum product price. Disable to set the range manually.":["\u6709\u52b9\u306b\u3059\u308b\u3068\u3001\u30b9\u30e9\u30a4\u30c0\u30fc\u306e\u7bc4\u56f2\u304c\u30b9\u30c8\u30a2\u306e\u5b9f\u969b\u306e\u5546\u54c1\u4fa1\u683c\u306e\u6700\u5c0f\u5024\u3068\u6700\u5927\u5024\u306b\u4e00\u81f4\u3057\u307e\u3059\u3002 \u7bc4\u56f2\u3092\u624b\u52d5\u3067\u8a2d\u5b9a\u3059\u308b\u5834\u5408\u306f\u7121\u52b9\u306b\u3057\u307e\u3059\u3002"],"Auto-detect range from store":["\u30b9\u30c8\u30a2\u304b\u3089\u7bc4\u56f2\u3092\u81ea\u52d5\u691c\u51fa"],"Slider range":["\u30b9\u30e9\u30a4\u30c0\u30fc\u7bc4\u56f2"],"After amount":["\u91d1\u984d\u306e\u5f8c"],"Before amount":["\u91d1\u984d\u306e\u524d"],"Default (WooCommerce)":["\u30c7\u30d5\u30a9\u30eb\u30c8 (WooCommerce)"],"Symbol position":["\u8a18\u53f7\u306e\u4f4d\u7f6e"],"Leave blank to use the active WooCommerce currency.":["\u6709\u52b9\u306a WooCommerce \u901a\u8ca8\u3092\u4f7f\u7528\u3059\u308b\u306b\u306f\u3001\u7a7a\u767d\u306e\u307e\u307e\u306b\u3057\u307e\u3059\u3002"],"Currency symbol":["\u901a\u8ca8\u8a18\u53f7"],"Adds a draggable range slider above the number inputs. Mirrors WooCommerce Blocks\u2019 price slider.":["\u6570\u5b57\u306e\u5165\u529b\u6b04\u306e\u4e0a\u306b\u30c9\u30e9\u30c3\u30b0\u53ef\u80fd\u306a\u7bc4\u56f2\u30b9\u30e9\u30a4\u30c0\u30fc\u3092\u8ffd\u52a0\u3057\u307e\u3059\u3002 WooCommerce \u30d6\u30ed\u30c3\u30af\u306e\u4fa1\u683c\u30b9\u30e9\u30a4\u30c0\u30fc\u3068\u540c\u69d8\u306e\u6a5f\u80fd\u3067\u3059\u3002"],"Show slider":["\u30b9\u30e9\u30a4\u30c0\u30fc\u3092\u8868\u793a"],"Filter by Product Attribute":["\u5546\u54c1\u5c5e\u6027\u3067\u7d5e\u308a\u8fbc\u3080"],"By count (most matches first)":["\u4ef6\u6570\u9806 (\u4e00\u81f4\u4ef6\u6570\u304c\u591a\u3044\u9806)"],"Maximum items shown":["\u8868\u793a\u3059\u308b\u30a2\u30a4\u30c6\u30e0\u306e\u6700\u5927\u6570"],"Heading shown above the options. Leave empty to use the attribute's name.":["\u30aa\u30d7\u30b7\u30e7\u30f3\u306e\u4e0a\u306b\u8868\u793a\u3055\u308c\u308b\u898b\u51fa\u3057\u3002 \u5c5e\u6027\u306e\u540d\u524d\u3092\u4f7f\u7528\u3059\u308b\u5834\u5408\u306f\u3001\u7a7a\u306e\u307e\u307e\u306b\u3057\u307e\u3059\u3002"],"\u2014 Select an attribute \u2014":["- \u5c5e\u6027\u3092\u9078\u629e -"],"Attribute":["\u5c5e\u6027"],"No WooCommerce product attributes are registered on this site, so this block has nothing to filter on.":["\u3053\u306e\u30b5\u30a4\u30c8\u306b\u306f WooCommerce \u5546\u54c1\u5c5e\u6027\u304c\u767b\u9332\u3055\u308c\u3066\u3044\u306a\u3044\u305f\u3081\u3001\u3053\u306e\u30d6\u30ed\u30c3\u30af\u3067\u30d5\u30a3\u30eb\u30bf\u30fc\u3067\u304d\u308b\u9805\u76ee\u306f\u3042\u308a\u307e\u305b\u3093\u3002"],"Pick a WooCommerce product attribute in the block sidebar to enable this filter.":["\u3053\u306e\u30d5\u30a3\u30eb\u30bf\u30fc\u3092\u6709\u52b9\u306b\u3059\u308b\u306b\u306f\u3001\u30d6\u30ed\u30c3\u30af\u30b5\u30a4\u30c9\u30d0\u30fc\u3067 WooCommerce \u5546\u54c1\u5c5e\u6027\u3092\u9078\u629e\u3057\u307e\u3059\u3002"],"No WooCommerce product attributes were found on this site.":["\u3053\u306e\u30b5\u30a4\u30c8\u306b\u306f WooCommerce \u5546\u54c1\u5c5e\u6027\u304c\u898b\u3064\u304b
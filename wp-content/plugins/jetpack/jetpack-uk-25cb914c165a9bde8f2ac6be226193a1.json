437\u0430\u043f\u0438\u0441\u0443."],"Search scope":["\u041e\u0431\u043b\u0430\u0441\u0442\u044c \u043f\u043e\u0448\u0443\u043a\u0443"],"Shown when a search request fails. Leave empty for the default.":["\u0412\u0456\u0434\u043e\u0431\u0440\u0430\u0436\u0430\u0454\u0442\u044c\u0441\u044f \u0443 \u0440\u0430\u0437\u0456 \u043d\u0435\u0432\u0434\u0430\u043b\u043e\u0433\u043e \u0432\u0438\u043a\u043e\u043d\u0430\u043d\u043d\u044f \u043f\u043e\u0448\u0443\u043a\u043e\u0432\u043e\u0433\u043e \u0437\u0430\u043f\u0438\u0442\u0443. \u0417\u0430\u043b\u0438\u0448\u0442\u0435 \u043f\u043e\u043b\u0435 \u043f\u043e\u0440\u043e\u0436\u043d\u0456\u043c, \u0449\u043e\u0431 \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u0432\u0430\u0442\u0438 \u0437\u043d\u0430\u0447\u0435\u043d\u043d\u044f \u0437\u0430 \u0437\u0430\u043c\u043e\u0432\u0447\u0443\u0432\u0430\u043d\u043d\u044f\u043c."],"Error message":["\u041f\u043e\u0432\u0456\u0434\u043e\u043c\u043b\u0435\u043d\u043d\u044f \u043f\u0440\u043e \u043f\u043e\u043c\u0438\u043b\u043a\u0443"],"Shown when active filters return zero results. Leave empty for the default.":["\u0412\u0456\u0434\u043e\u0431\u0440\u0430\u0436\u0430\u0454\u0442\u044c\u0441\u044f, \u043a\u043e\u043b\u0438 \u0430\u043a\u0442\u0438\u0432\u043d\u0456 \u0444\u0456\u043b\u044c\u0442\u0440\u0438 \u043d\u0435 \u0434\u0430\u044e\u0442\u044c \u0436\u043e\u0434\u043d\u0438\u0445 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u0456\u0432. \u0417\u0430\u043b\u0438\u0448\u0442\u0435 \u043f\u043e\u0440\u043e\u0436\u043d\u0456\u043c \u0434\u043b\u044f \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u0430\u043d\u043d\u044f \u0437\u043d\u0430\u0447\u0435\u043d\u043d\u044f \u0437\u0430 \u0437\u0430\u043c\u043e\u0432\u0447\u0443\u0432\u0430\u043d\u043d\u044f\u043c."],"No-results message (when filters are active)":["\u041f\u043e\u0432\u0456\u0434\u043e\u043c\u043b\u0435\u043d\u043d\u044f \u043f\u0440\u043e \u0432\u0456\u0434\u0441\u0443\u0442\u043d\u0456\u0441\u0442\u044c \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u0456\u0432 (\u044f\u043a\u0449\u043e \u0430\u043a\u0442\u0438\u0432\u043e\u0432\u0430\u043d\u0456 \u0444\u0456\u043b\u044c\u0442\u0440\u0438)"],"Shown when a search returns nothing. Leave empty for the default.":["\u0412\u0456\u0434\u043e\u0431\u0440\u0430\u0436\u0430\u0454\u0442\u044c\u0441\u044f, \u043a\u043e\u043b\u0438 \u043f\u043e\u0448\u0443\u043a \u043d\u0435 \u0434\u0430\u0432 \u0436\u043e\u0434\u043d\u0438\u0445 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u0456\u0432. \u0417\u0430\u043b\u0438\u0448\u0442\u0435 \u043f\u043e\u043b\u0435 \u043f\u043e\u0440\u043e\u0436\u043d\u0456\u043c, \u0449\u043e\u0431 \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u0432\u0430\u0442\u0438 \u0437\u043d\u0430\u0447\u0435\u043d\u043d\u044f \u0437\u0430 \u0437\u0430\u043c\u043e\u0432\u0447\u0443\u0432\u0430\u043d\u043d\u044f\u043c."],"No-results message":["\u041f\u043e\u0432\u0456\u0434\u043e\u043c\u043b\u0435\u043d\u043d\u044f, \u044f\u043a\u0449\u043e \u043d\u0456\u0447\u043e\u0433\u043e \u043d\u0435 \u0437\u043d\u0430\u0439\u0434\u0435\u043d\u043e"],"Exclude: %s":["\u0412\u0438\u043a\u043b\u044e\u0447\u0438\u0442\u0438: %s"],"Include only: %s":["\u0412\u043a\u043b\u044e\u0447\u0438\u0442\u0438 \u0442\u0456\u043b\u044c\u043a\u0438: %s"],"All post types":["\u0412\u0441\u0456 \u0442\u0438\u043f\u0438 \u0437\u0430\u043f\u0438\u0441\u0456\u0432"],"Compact":["\u041a\u043e\u043c\u043f\u0430\u043a\u0442\u043d\u043e"],"Third product":["\u0422\u0440\u0435\u0442\u0456\u0439 \u0442\u043e\u0432\u0430\u0440"],"Another product on sale":["\u0406\u043d\u0448\u0438\u0439 \u0442\u043e\u0432\u0430\u0440 \u0437\u0456 \u0437\u043d\u0438\u0436\u043a\u043e\u044e"],"Sample product":["\u041f\u0440\u0438\u043a\u043b\u0430\u0434 \u0442\u043e\u0432\u0430\u0440\u0443"],"Matches content: an older post with a brief excerpt showing the matched text.":["\u0417\u0431\u0456\u0433 \u0443 \u0442\u0435\u043a\u0441\u0442\u0456: \u043f\u0440\u0438\u043a\u043b\u0430\u0434 \u0437\u0430\u043f\u0438\u0441\u0443 \u0437 \u0444\u0440\u0430\u0433\u043c\u0435\u043d\u0442\u043e\u043c \u0437\u043d\u0430\u0439\u0434\u0435\u043d\u043e\u0433\u043e \u0442\u0435\u043a\u0441\u0442\u0443."],"A. Writer, B. Editor":["\u0410. \u0410\u0432\u0442\u043e\u0440, \u0411. \u0420\u0435\u0434\u0430\u043a\u0442\u043e\u0440"],"Matches content: a second excerpt demonstrating how content highlights appear in results.":["\u0417\u0431\u0456\u0433 \u0443 \u0442\u0435\u043a\u0441\u0442\u0456: \u0434\u0440\u0443\u0433\u0438\u0439 \u0444\u0440\u0430\u0433\u043c\u0435\u043d\u0442, \u0449\u043e \u0434\u0435\u043c\u043e\u043d\u0441\u0442\u0440\u0443\u0454 \u0432\u0438\u0434\u0456\u043b\u0435\u043d\u043d\u044f \u0437\u043d\u0430\u0439\u0434\u0435\u043d\u0438\u0445 \u0441\u043b\u0456\u0432."],"Sample Author":["\u041f\u0440\u0438\u043a\u043b\u0430\u0434 \u0430\u0432\u0442\u043e\u0440\u0430"],"Matches content: this snippet shows the relevant passage that matched your search query.":["\u0417\u0431\u0456\u0433 \u0443 \u0442\u0435\u043a\u0441\u0442\u0456: \u0446\u0435\u0439 \u0444\u0440\u0430\u0433\u043c\u0435\u043d\u0442 \u043f\u043e\u043a\u0430\u0437\u0443\u0454 \u0447\u0430\u0441\u0442\u0438\u043d\u0443 \u0432\u043c\u0456\u0441\u0442\u0443, \u0449\u043e \u0432\u0456\u0434\u043f\u043e\u0432\u0456\u0434\u0430\u0454 \u043f\u043e\u0448\u0443\u043a\u043e\u0432\u043e\u043c\u0443 \u0437\u0430\u043f\u0438\u0442\u0443."],"Hide filter panel":["\u041f\u0440\u0438\u0445\u043e\u0432\u0430\u0442\u0438 \u043f\u0430\u043d\u0435\u043b\u044c \u0444\u0456\u043b\u044c\u0442\u0440\u0430"],"Show filter panel":["\u041f\u043e\u043a\u0430\u0437\u0430\u0442\u0438 \u043f\u0430\u043d\u0435\u043b\u044c \u0444\u0456\u043b\u044c\u0442\u0440\u0430"],"Heading shown above the options. Leave empty for the default.":["\u0417\u0430\u0433\u043e\u043b\u043e\u0432\u043e\u043a, \u0449\u043e \u0432\u0456\u0434\u043e\u0431\u0440\u0430\u0436\u0430\u0454\u0442\u044c\u0441\u044f \u043d\u0430\u0434 \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u0430\u043c\u0438. \u0417\u0430\u043b\u0438\u0448\u0442\u0435 \u043f\u043e\u0440\u043e\u0436\u043d\u0456\u043c \u0434\u043b\u044f \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u0430\u043d\u043d\u044f \u0441\u0442\u0430\u043d\u0434\u0430\u0440\u0442\u043d\u043e\u0433\u043e \u0442\u0435\u043a\u0441\u0442\u0443."],"In stock":["\u0412 \u043d\u0430\u044f\u0432\u043d\u043e\u0441\u0442\u0456"],"Hide rows you don\u2019t want shoppers to pick. At least one row must stay visible.":["\u041f\u0440\u0438\u0445\u043e\u0432\u0430\u0442\u0438 \u0440\u044f\u0434\u043a\u0438, \u044f\u043a\u0456 \u043d\u0435 \u043c\u0430\u044e\u0442\u044c \u0431\u0443\u0442\u0438 \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u0456 \u0434\u043b\u044f \u0432\u0438\u0431\u043e\u0440\u0443 \u043f\u043e\u043a\u0443\u043f\u0446\u044f\u043c\u0438. \u041f\u0440\u0438\u043d\u0430\u0439\u043c\u043d\u0456 \u043e\u0434\u0438\u043d \u0440\u044f\u0434\u043e\u043a \u043c\u0430\u0454 \u0437\u0430\u043b\u0438\u0448\u0430\u0442\u0438\u0441\u044f \u0432\u0438\u0434\u0438\u043c\u0438\u043c."],"Visible rows":["\u0412\u0438\u0434\u0438\u043c\u0456 \u0440\u044f\u0434\u043a\u0438"],"Heading shown above the star rows. Leave empty for the default.":["\u0417\u0430\u0433\u043e\u043b\u043e\u0432\u043e\u043a, \u0449\u043e \u0432\u0456\u0434\u043e\u0431\u0440\u0430\u0436\u0430\u0454\u0442\u044c\u0441\u044f \u043d\u0430\u0434 \u0440\u044f\u0434\u043a\u0430\u043c\u0438 \u0437 \u0440\u0435\u0439\u0442\u0438\u043d\u0433\u043e\u043c. \u0417\u0430\u043b\u0438\u0448\u0442\u0435 \u043f\u043e\u0440\u043e\u0436\u043d\u0456\u043c \u0434\u043b\u044f \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u0430\u043d\u043d\u044f \u0441\u0442\u0430\u043d\u0434\u0430\u0440\u0442\u043d\u043e\u0433\u043e \u0442\u0435\u043a\u0441\u0442\u0443."],"Slider granularity.":["\u041a\u0440\u043e\u043a \u043f\u043e\u0432\u0437\u0443\u043d\u043a\u0430."],"Maximum":["\u041c\u0430\u043a\u0441\u0438\u043c\u0443\u043c"],"Minimum":["\u041c\u0456\u043d\u0456\u043c\u0443\u043c"],"Minimum must be less than maximum for the slider to render correctly.":["\u041c\u0456\u043d\u0456\u043c\u0430\u043b\u044c\u043d\u0435 \u0437\u043d\u0430\u0447\u0435\u043d\u043d\u044f \u043c\u0430\u0454 \u0431\u0443\u0442\u0438 \u043c\u0435\u043d\u0448\u0438\u043c \u0437\u0430 \u043c\u0430\u043a\u0441\u0438\u043c\u0430\u043b\u044c\u043d\u0435 \u0434\u043b\u044f \u043a\u043e\u0440\u0435\u043a\u0442\u043d\u043e\u0433\u043e \u0432\u0456\u0434\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u043d\u044f \u043f\u043e\u0432\u0437\u0443\u043d\u043a\u0430."],"When enabled, the slider bounds match the store\u2019s actual minimum and maximum product price. Disable to set the range manually.":["\u042f\u043a\u0449\u043e \u0443\u0432\u0456\u043c\u043a\u043d\u0435\u043d\u043e, \u043c\u0435\u0436\u0456 \u043f\u043e\u0432\u0437\u0443\u043d\u043a\u0430 \u0432\u0456\u0434\u043f\u043e\u0432\u0456\u0434\u0430\u0442\u0438\u043c\u0443\u0442\u044c \u0444\u0430\u043a\u0442\u0438\u0447\u043d\u0456\u0439 \u043c\u0456\u043d\u0456\u043c\u0430\u043b\u044c\u043d\u0456\u0439 \u0442\u0430 \u043c\u0430\u043a\u0441\u0438\u043c\u0430\u043b\u044c\u043d\u0456\u0439 \u0446\u0456\u043d\u0456 \u0442\u043e\u0432\u0430\u0440\u0456\u0432 \u0443 \u043c\u0430\u0433\u0430\u0437\u0438\u043d\u0456. \u0412\u0438\u043c\u043a\u043d\u0456\u0442\u044c, \u0449\u043e\u0431 \u0432\u0441\u0442\u0430\u043d\u043e\u0432\u0438\u0442\u0438 \u0434\u0456\u0430\u043f\u0430\u0437\u043e\u043d \u0441\u0430\u043c\u043e\u0441\u0442\u0456\u0439\u043d\u043e."],"Auto-detect range from store":["\u0410\u0432\u0442\u043e\u043c\u0430\u0442\u0438\u0447\u043d\u043e \u0432\u0438\u0437\u043d\u0430\u0447\u0430\u0442\u0438 \u0434\u0456\u0430\u043f\u0430\u0437\u043e\u043d \u0456\u0437 \u043c\u0430\u0433\u0430\u0437\u0438\u043d\u0443"],"Slider range":["\u0414\u0456\u0430\u043f\u0430\u0437\u043e\u043d \u043f\u043e\u0432\u0437\u0443\u043d\u043a\u0430"],"After amount":["\u041f\u0456\u0441\u043b\u044f \u0441\u0443\u043c\u0438"],"Before amount":["\u041f\u0435\u0440\u0435\u0434 \u0441\u0443\u043c\u043e\u044e"],"Default (WooCommerce)":["\u0421\u0442\u0430\u043d\u0434\u0430\u0440\u0442\u043d\u043e (WooCommerce)"],"Symbol position":["\u041f\u043e\u0437\u0438\u0446\u0456\u044f \u0441\u0438\u043c\u0432\u043e\u043b\u0443"],"Leave blank to use the active WooCommerce currency.":["\u0417\u0430\u043b\u0438\u0448\u0442\u0435 \u043f\u043e\u0440\u043e\u0436\u043d\u0456\u043c, \u0449\u043e\u0431 \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u0432\u0430\u0442\u0438 \u043f\u043e\u0442\u043e\u0447\u043d\u0443 \u0432\u0430\u043b\u044e\u0442\u0443 WooCommerce."],"Currency symbol":["\u0421\u0438\u043c\u0432\u043e\u043b \u0432\u0430\u043b\u044e\u0442\u0438"],"Adds a draggable range slider above the number inputs. Mirrors WooCommerce Blocks\u2019 price slider.":["\u0414\u043e\u0434\u0430\u0454 \u043f\u043e\u0432\u0437\u0443\u043d\u043e\u043a \u0434\u0456\u0430\u043f\u0430\u0437\u043e\u043d\u0443 \u043d\u0430\u0434 \u043f\u043e\u043b\u044f\u043c\u0438 \u0432\u0432\u0435\u0434\u0435\u043d\u043d\u044f \u0447\u0438\u0441\u0435\u043b. \u041f\u043e\u0432\u0442\u043e\u0440\u044e\u0454 \u0444\u0443\u043d\u043a\u0446\u0456\u043e\u043d\u0430\u043b \u0446\u0456\u043d\u043e\u0432\u043e\u0433\u043e \u043f\u043e\u0432\u0437\u0443\u043d\u043a\u0430 \u0431\u043b\u043e\u043a\u0456\u0432 WooCommerce."],"Show slider":["\u041f\u043e\u043a\u0430\u0437\u0430\u0442\u0438 \u043f\u043e\u0432\u0437\u0443\u043d\u043e\u043a"],"Filter by Product Attribute":["\u0424\u0456\u043b\u044c\u0442\u0440 \u0437\u0430 \u0430\u0442\u0440\u0438\u0431\u0443\u0442\u043e\u043c \u0442\u043e\u0432\u0430\u0440\u0443"],"By count (most matches first)":["\u0417\u0430 \u043a\u0456\u043b\u044c\u043a\u0456\u0441\u0442\u044e (\u0441\u043f\u043e\u0447\u0430\u0442\u043a\u0443 \u0437 \u043d\u0430\u0439\u0431\u0456\u043b\u044c\u0448\u043e\u044e \u043a\u0456\u043b\u044c\u043a\u0456\u0441\u0442\u044e \u0437\u0431\u0456\u0433\u0456\u0432)"],"Maximum items shown":["\u041c\u0430\u043a\u0441\u0438\u043c\u0430\u043b\u044c\u043d\u0430 \u043a\u0456\u043b\u044c\u043a\u0456\u0441\u0442\u044c \u0435\u043b\u0435\u043c\u0435\u043d\u0442\u0456\u0432 \u0434\u043b\u044f \u0432\u0456\u0434\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u043d\u044f"],"Heading shown above the options. Leave empty to use the attribute's name.":["\u0417\u0430\u0433\u043e\u043b\u043e\u0432\u043e\u043a, \u0449\u043e \u0432\u0456\u0434\u043e\u0431\u0440\u0430\u0436\u0430\u0454\u0442\u044c\u0441\u044f \u043d\u0430\u0434 \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u0430\u043c\u0438. \u0417\u0430\u043b\u0438\u0448\u0442\u0435 \u043f\u043e\u0440\u043e\u0436\u043d\u0456\u043c, \u0449\u043e\u0431 \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u0432\u0430\u0442\u0438 \u043d\u0430\u0437\u0432\u0443 \u0430\u0442\u0440\u0438\u0431\u0443\u0442\u0430."],"\u2014 Select an attribute \u2014":["\u2014 \u0412\u0438\u0431\u0440\u0430\u0442\u0438 \u0430\u0442\u0440\u0438\u0431\u0443\u0442 \u2014"],"Attribute":["\u0410\u0442\u0440\u0438\u0431\u0443\u0442"],"No WooCommerce product attributes are registered on this site, so this block has nothing to filter on.":["\u041d\u0430 \u0446\u044c\u043e\u043c\u0443 \u0441\u0430\u0439\u0442\u0456 \u043d\u0435 \u0437\u0430\u0440\u0435\u0454\u0441\u0442\u0440\u043e\u0432\u0430\u043d\u043e \u0436\u043e\u0434\u043d\u043e\u0433\u043e \u0430\u0442\u0440\u0438\u0431\u0443\u0442\u0430 \u0442\u043e\u0432\u0430\u0440\u0456\u0432 WooCommerce, \u0442\u043e\u043c\u0443 \u0446\u044c\u043e\u043c\u0443 \u0431\u043b\u043e\u043a\u0443 \u043d\u0435\u043c\u0430\u0454 \u0437\u0430 \u0447\u0438\u043c \u0444\u0456\u043b\u044c\u0442\u0440\u0443\u0432\u0430\u0442\u0438."],"Pick a WooCommerce product attribute in the block sidebar to enable this filter.":["\u0412\u0438\u0431\u0435\u0440\u0456\u0442\u044c \u0430\u0442\u0440\u0438\u0431\u0443\u0442 \u0442\u043e\u0432\u0430\u0440\u0443 WooCommerce \u0443 \u0431\u0456\u0447\u043d\u0456\u0439 \u043f\u0430\u043d\u0435\u043b\u0456 \u0431\u043b\u043e\u043a\u0430, \u0449\u043e\u0431 \u0443\u0432\u0456\u043c\u043a\u043d\u0443\u0442\u0438 \u0446\u0435\u0439 \u0444\u0456\u043b\u044c\u0442\u0440."],"No WooCommerce product attributes were found on this site.":["\u041d\u0430 \u0446\u044c\u043e\u043c\u0443 \u0441\u0430\u0439\u0442\u0456 \u043d\u0435 \u0437\u043d\u0430\u0439\u0434\u0435\u043d\u043e \u0436\u043e\u0434\u043d\u043e\u0433\u043e \u0430\u0442\u0440\u0438\u0431\u0443\u0442\u0430 \u0442\u043e\u0432\u0430\u0440\u0456\u0432 WooCommerce."],"Pick which WooCommerce product attribute drives this filter.":["\u0412\u0438\u0431\u0435\u0440\u0456\u0442\u044c \u0430\u0442\u0440\u0438\u0431\u0443\u0442 \u0442\u043e\u0432\u0430\u0440\u0443 WooCommerce, \u0437\u0430 \u044f\u043a\u0438\u043c \u043f\u0440\u0430\u0446\u044e\u0432\u0430\u0442\u0438\u043c\u0435 \u0446\u0435\u0439 \u0444\u0456\u043b\u044c\u0442\u0440."],"Loading product attributes\u2026":["\u0417\u0430\u0432\u0430\u043d\u0442\u0430\u0436\u0435\u043d\u043d\u044f \u0430\u0442\u0440\u0438\u0431\u0443\u0442\u0456\u0432 \u0442\u043e\u0432\u0430\u0440\u0456\u0432\u2026"],"Any":["\u0411\u0443\u0434\u044c-\u044f\u043a\u0438\u0439"],"Show posts that match any of the selected options.":["\u041f\u043e\u043a\u0430\u0437\u0443\u0432\u0430\u0442\u0438 \u0437\u0430\u043f\u0438\u0441\u0438, \u0449\u043e \u0432\u0456\u0434\u043f\u043e\u0432\u0456\u0434\u0430\u044e\u0442\u044c \u0431\u0443\u0434\u044c-\u044f\u043a\u043e\u043c\u0443 \u0437 \u0432\u0438\u0431\u0440\u0430\u043d\u0438\u0445 \u0432\u0430\u0440\u0456\u0430\u043d\u0442\u0456\u0432."],"Show posts that match all selected options.":["\u041f\u043e\u043a\u0430\u0437\u0443\u0432\u0430\u0442\u0438 \u0437\u0430\u043f\u0438\u0441\u0438, \u0449\u043e \u0432\u0456\u0434\u043f\u043e\u0432\u0456\u0434\u0430\u044e\u0442\u044c \u0443\u0441\u0456\u043c \u0432\u0438\u0431\u0440\u0430\u043d\u0438\u043c \u0432\u0430\u0440\u0456\u0430\u043d\u0442\u0430\u043c."],"Logic":["\u041b\u043e\u0433\u0456\u043a\u0430"],"Chips":["\u041a\u043d\u043e\u043f\u043a\u0438-\u043c\u0456\u0442\u043a\u0438"],"Checkbox list":["\u0421\u043f\u0438\u0441\u043e\u043a \u0432\u0438\u0431\u043e\u0440\u0443 \u0432\u0430\u0440\u0456\u0430\u043d\u0442\u0456\u0432"],"Display style":["\u0421\u0442\u0438\u043b\u044c \u0432\u0456\u0434\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u043d\u044f"],"Pick which registered taxonomy this filter targets. Only taxonomies that Jetpack Search indexes (natively or via a jetpack-search-tagN slot mapping) appear here; \"(mapped)\" flags a slot-routed entry.":["\u0412\u0438\u0431\u0435\u0440\u0456\u0442\u044c, \u043d\u0430 \u044f\u043a\u0443 \u0437\u0430\u0440\u0435\u0454\u0441\u0442\u0440\u043e\u0432\u0430\u043d\u0443 \u0442\u0430\u043a\u0441\u043e\u043d\u043e\u043c\u0456\u044e \u0441\u043f\u0440\u044f\u043c\u043e\u0432\u0430\u043d\u0438\u0439 \u0446\u0435\u0439 \u0444\u0456\u043b\u044c\u0442\u0440. \u0422\u0443\u0442 \u0432\u0456\u0434\u043e\u0431\u0440\u0430\u0436\u0430\u044e\u0442\u044c\u0441\u044f \u043b\u0438\u0448\u0435 \u0442\u0456 \u0442\u0430\u043a\u0441\u043e\u043d\u043e\u043c\u0456\u0457, \u044f\u043a\u0456 \u0456\u043d\u0434\u0435\u043a\u0441\u0443\u0454 Jetpack Search (\u043d\u0430\u0442\u0438\u0432\u043d\u043e \u0430\u0431\u043e \u0447\u0435\u0440\u0435\u0437 \u043f\u0440\u0438\u0432\u2019\u044f\u0437\u043a\u0443 \u0434\u043e \u0441\u043b\u043e\u0442\u0456\u0432 jetpack-search-tagN); \u043f\u043e\u0437\u043d\u0430\u0447\u043a\u0430 \"(\u043f\u0440\u0438\u0432'\u044f\u0437\u0430\u043d\u043e)\" \u0432\u043a\u0430\u0437\u0443\u0454 \u043d\u0430 \u0437\u0430\u043f\u0438\u0441 \u0456\u0437 \u043c\u0430\u0440\u0448\u0440\u0443\u0442\u0438\u0437\u0430\u0446\u0456\u0454\u044e \u0447\u0435\u0440\u0435\u0437 \u0441\u043b\u043e\u0442\u0438."],"Jetpack Search doesn't index any custom taxonomies on this site. Map one to a reserved jetpack-search-tagN slot via the jetpack_search_custom_taxonomy_map filter, or add it to Jetpack Search's allowlist, and it will appear here.":["Jetpack Search \u043d\u0435 \u0456\u043d\u0434\u0435\u043a\u0441\u0443\u0454 \u0436\u043e\u0434\u043d\u043e\u0457 \u043a\u043e\u0440\u0438\u0441\u0442\u0443\u0432\u0430\u0446\u044c\u043a\u043e\u0457 \u0442\u0430\u043a\u0441\u043e\u043d\u043e\u043c\u0456\u0457 \u043d\u0430 \u0446\u044c\u043e\u043c\u0443 \u0441\u0430\u0439\u0442\u0456. \u041f\u0440\u0438\u0432\u2019\u044f\u0436\u0456\u0442\u044c \u043e\u0434\u043d\u0443 \u0437 \u043d\u0438\u0445 \u0434\u043e \u0437\u0430\u0440\u0435\u0437\u0435\u0440\u0432\u043e\u0432\u0430\u043d\u043e\u0433\u043e \u0441\u043b\u043e\u0442\u0430 jetpack-search-tagN \u0437\u0430 \u0434\u043e\u043f\u043e\u043c\u043e\u0433\u043e\u044e \u0444\u0456\u043b\u044c\u0442\u0440\u0430 jetpack_search_custom_taxonomy_map or \u0434\u043e\u0434\u0430\u0439\u0442\u0435 \u0457\u0457 \u0434\u043e \u0434\u043e\u0437\u0432\u043e\u043b\u0435\u043d\u043e\u0433\u043e \u0441\u043f\u0438\u0441\u043a\u0443 (allowlist) Jetpack Search, \u0456 \u0432\u043e\u043d\u0430 \u0437\u2019\u044f\u0432\u0438\u0442\u044c\u0441\u044f \u0442\u0443\u0442."],"%s (mapped)":["%s (\u043f\u0440\u0438\u0432'\u044f\u0437\u0430\u043d\u043e)"],"Reveal the button only once the shopper selects a filter or price range.":["\u041f\u043e\u043a\u0430\u0437\u0443\u0432\u0430\u0442\u0438 \u043a\u043d\u043e\u043f\u043a\u0443 \u043b\u0438\u0448\u0435 \u043f\u0456\u0441\u043b\u044f \u0442\u043e\u0433\u043e, \u044f\u043a \u043f\u043e\u043a\u0443\u043f\u0435\u0446\u044c \u043e\u0431\u0435\u0440\u0435 \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440 \u0444\u0456\u043b\u044c\u0442\u0440\u0430 \u0430\u0431\u043e \u0434\u0456\u0430\u043f\u0430\u0437\u043e\u043d \u0446\u0456\u043d."],"Hide when no filter is active":["\u041f\u0440\u0438\u0445\u043e\u0432\u0430\u0442\u0438, \u044f\u043a\u0449\u043e \u043d\u0435\u043c\u0430\u0454 \u0430\u043a\u0442\u0438\u0432\u043d\u0438\u0445 \u0444\u0456\u043b\u044c\u0442\u0440\u0456\u0432"],"Once a visitor searches, an AI-generated answer will appear here with citations drawn from your site.":["\u041a\u043e\u043b\u0438 \u0432\u0456\u0434\u0432\u0456\u0434\u0443\u0432\u0430\u0447 \u0432\u0438\u043a\u043e\u043d\u0430\u0454 \u043f\u043e\u0448\u0443\u043a, \u0442\u0443\u0442 \u0437'\u044f\u0432\u0438\u0442\u044c\u0441\u044f \u0432\u0456\u0434\u043f\u043e\u0432\u0456\u0434\u044c, \u0437\u0433\u0435\u043d\u0435\u0440\u043e\u0432\u0430\u043d\u0430 \u0448\u0442\u0443\u0447\u043d\u0438\u043c \u0456\u043d\u0442\u0435\u043b\u0435\u043a\u0442\u043e\u043c, \u0456\u0437 \u043f\u043e\u0441\u0438\u043b\u0430\u043d\u043d\u044f\u043c\u0438 \u043d\u0430 \u0434\u0436\u0435\u0440\u0435\u043b\u0430 \u0437 \u0432\u0430\u0448\u043e\u0433\u043e \u0441\u0430\u0439\u0442\u0443."],"After the brief answer arrives, offer a button that loads a longer, more detailed response.":["\u041f\u0456\u0441\u043b\u044f \u043f\u043e\u044f\u0432\u0438 \u043a\u043e\u0440\u043e\u0442\u043a\u043e\u0457 \u0432\u0456\u0434\u043f\u043e\u0432\u0456\u0434\u0456 \u043f\u043e\u043a\u0430\u0437\u0443\u0432\u0430\u0442\u0438 \u043a\u043d\u043e\u043f\u043a\u0443 \u0434\u043b\u044f \u0437\u0430\u0432\u0430\u043d\u0442\u0430\u0436\u0435\u043d\u043d\u044f \u0434\u043e\u0432\u0448\u043e\u0457 \u0442\u0430 \u0434\u0435\u0442\u0430\u043b\u044c\u043d\u0456\u0448\u043e\u0457 \u0432\u0435\u0440\u0441\u0456\u0457."],"Allow \"Show more\" for a longer answer":["\u0423\u0432\u0456\u043c\u043a\u043d\u0456\u0442\u044c \u043e\u043f\u0446\u0456\u044e \"\u0427\u0438\u0442\u0430\u0442\u0438 \u043f\u043e\u0432\u043d\u0456\u0441\u0442\u044e\", \u0449\u043e\u0431 \u043f\u043e\u0431\u0430\u0447\u0438\u0442\u0438 \u043f\u043e\u0432\u043d\u0443 \u0432\u0456\u0434\u043f\u043e\u0432\u0456\u0434\u044c"],"Display the sources used by the AI under the answer.":["\u041f\u043e\u043a\u0430\u0437\u0443\u0432\u0430\u0442\u0438 \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u0430\u043d\u0456 \u0428\u0406 \u0434\u0436\u0435\u0440\u0435\u043b\u0430 \u043f\u0456\u0434 \u0432\u0456\u0434\u043f\u043e\u0432\u0456\u0434\u0434\u044e."],"Show citations":["\u041f\u043e\u043a\u0430\u0437\u0443\u0432\u0430\u0442\u0438 \u0434\u0436\u0435\u0440\u0435\u043b\u0430"],"Label shown above the answer. Leave empty for the default.":["\u041c\u0456\u0442\u043a\u0430, \u0449\u043e \u0432\u0456\u0434\u043e\u0431\u0440\u0430\u0436\u0430\u0454\u0442\u044c\u0441\u044f \u043d\u0430\u0434 \u0432\u0456\u0434\u043f\u043e\u0432\u0456\u0434\u0434\u044e. \u0417\u0430\u043b\u0438\u0448\u0442\u0435 \u043f\u043e\u0440\u043e\u0436\u043d\u0456\u043c, \u0449\u043e\u0431 \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u0432\u0430\u0442\u0438 \u0437\u0430 \u0437\u0430\u043c\u043e\u0432\u0447\u0443\u0432\u0430\u043d\u043d\u044f\u043c."],"AI Answer is part of the paid Jetpack Search plan. Upgrade to enable AI-generated answers with citations on your search results.":["\u0411\u043b\u043e\u043a \u00ab\u0412\u0456\u0434\u043f\u043e\u0432\u0456\u0434\u044c \u0428\u0406\u00bb \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u0438\u0439 \u043b\u0438\u0448\u0435 \u0443 \u043f\u043b\u0430\u0442\u043d\u0438\u0445 \u0442\u0430\u0440\u0438\u0444\u0430\u0445 Jetpack Search. \u041f\u043e\u043a\u0440\u0430\u0449\u0442\u0435 \u0441\u0432\u0456\u0439 \u0442\u0430\u0440\u0438\u0444\u043d\u0438\u0439 \u043f\u043b\u0430\u043d, \u0449\u043e\u0431 \u0443\u0432\u0456\u043c\u043a\u043d\u0443\u0442\u0438 \u0432\u0456\u0434\u043f\u043e\u0432\u0456\u0434\u0456 \u0428\u0406 \u0437 \u043f\u043e\u0441\u0438\u043b\u0430\u043d\u043d\u044f\u043c\u0438 \u043d\u0430 \u0434\u0436\u0435\u0440\u0435\u043b\u0430 \u0443 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u0430\u0445 \u043f\u043e\u0448\u0443\u043a\u0443."],"AI Answer":["\u0412\u0456\u0434\u043f\u043e\u0432\u0456\u0434\u044c \u0428\u0406"],"No results match these filters. Try clearing some, or searching for something else.":["\u0420\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u0456\u0432, \u0449\u043e \u0432\u0456\u0434\u043f\u043e\u0432\u0456\u0434\u0430\u044e\u0442\u044c \u0446\u0438\u043c \u0444\u0456\u043b\u044c\u0442\u0440\u0430\u043c, \u043d\u0435 \u0437\u043d\u0430\u0439\u0434\u0435\u043d\u043e. \u0421\u043f\u0440\u043e\u0431\u0443\u0439\u0442\u0435 \u043f\u0440\u0438\u0431\u0440\u0430\u0442\u0438 \u0434\u0435\u044f\u043a\u0456 \u0437 \u043d\u0438\u0445 \u0430\u0431\u043e \u0432\u0438\u043a\u043e\u043d\u0430\u0442\u0438 \u0456\u043d\u0448\u0438\u0439 \u043f\u043e\u0448\u0443\u043a."],"Stock status":["\u0421\u0442\u0430\u0442\u0443\u0441 \u0437\u0430\u043f\u0430\u0441\u0456\u0432"],"rating filter row, e.g. \"\u2605\u2605\u2605\u2605 & up\"\u0004& up":["\u0439 \u0432\u0438\u0449\u0435"],"%d star and up":["%d \u0437\u0456\u0440\u043a\u0430 \u0439 \u0432\u0438\u0449\u0435","%d \u0437\u0456\u0440\u043a\u0438 \u0439 \u0432\u0438\u0449\u0435","%d \u0437\u0456\u0440\u043e\u043a \u0439 \u0432\u0438\u0449\u0435"],"5 stars":["5 \u0437\u0456\u0440\u043e\u043a"],"Max":["\u041c\u0430\u043a\u0441\u0438\u043c\u0443\u043c"],"Min":["\u041c\u0456\u043d\u0456\u043c\u0443\u043c"],"Product Brand":["\u0411\u0440\u0435\u043d\u0434 \u0442\u043e\u0432\u0430\u0440\u0443"],"Product Tag":["\u0422\u0435\u0433 \u0442\u043e\u0432\u0430\u0440\u0443"],"Product Category":["\u041a\u0430\u0442\u0435\u0433\u043e\u0440\u0456\u044f \u0442\u043e\u0432\u0430\u0440\u0443"],"AI answer":["\u0412\u0456\u0434\u043f\u043e\u0432\u0456\u0434\u044c \u0428\u0406"],"Categories & tags":["\u041a\u0430\u0442\u0435\u0433\u043e\u0440\u0456\u0457 \u0442\u0430 \u043f\u043e\u0437\u043d\u0430\u0447\u043a\u0438"],"Available options":["\u0414\u043e\u0441\u0442\u0443\u043f\u043d\u0456 \u0432\u0430\u0440\u0456\u0430\u043d\u0442\u0438"],"Popover":["\u0421\u043f\u043b\u0438\u0432\u0430\u044e\u0447\u0435 \u0432\u0456\u043a\u043d\u043e"],"Inline links":["\u0412\u0431\u0443\u0434\u043e\u0432\u0430\u043d\u0456 \u043f\u043e\u0441\u0438\u043b\u0430\u043d\u043d\u044f"],"Display as":["\u0412\u0456\u0434\u043e\u0431\u0440\u0430\u0436\u0430\u0442\u0438 \u044f\u043a"],"Applied on first load when the URL carries no sort parameter.":["\u0417\u0430\u0441\u0442\u043e\u0441\u043e\u0432\u0443\u0454\u0442\u044c\u0441\u044f \u043f\u0440\u0438 \u043f\u0435\u0440\u0448\u043e\u043c\u0443 \u0437\u0430\u0432\u0430\u043d\u0442\u0430\u0436\u0435\u043d\u043d\u0456, \u043a\u043e\u043b\u0438 URL-\u0430\u0434\u0440\u0435\u0441\u0430 \u043d\u0435 \u043c\u0456\u0441\u0442\u0438\u0442\u044c \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u0430 \u0441\u043e\u0440\u0442\u0443\u0432\u0430\u043d\u043d\u044f."],"Older archived entry":["\u0421\u0442\u0430\u0440\u0456\u0448\u0438\u0439 \u0437\u0430\u043f\u0438\u0441 \u0432 \u0430\u0440\u0445\u0456\u0432\u0456"],"Another relevant post":["\u0429\u0435 \u043e\u0434\u0438\u043d \u0432\u0456\u0434\u043f\u043e\u0432\u0456\u0434\u043d\u0438\u0439 \u0437\u0430\u043f\u0438\u0441"],"First sample result":["\u0420\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u0438 \u043f\u0435\u0440\u0448\u043e\u0433\u043e \u0437\u0440\u0430\u0437\u043a\u0430"],"When enabled, queries fire on Enter or when clearing the field, instead of on every keystroke.":["\u042f\u043a\u0449\u043e \u0446\u044f \u043e\u043f\u0446\u0456\u044f \u0443\u0432\u0456\u043c\u043a\u043d\u0435\u043d\u0430, \u0437\u0430\u043f\u0438\u0442\u0438 \u0432\u0438\u043a\u043e\u043d\u0443\u044e\u0442\u044c\u0441\u044f \u043f\u0440\u0438 \u043d\u0430\u0442\u0438\u0441\u043a\u0430\u043d\u043d\u0456 \u043a\u043b\u0430\u0432\u0456\u0448\u0456 Enter \u0430\u0431\u043e \u043f\u0440\u0438 \u043e\u0447\u0438\u0449\u0435\u043d\u043d\u0456 \u043f\u043e\u043b\u044f, \u0430 \u043d\u0435 \u043f\u0440\u0438 \u043a\u043e\u0436\u043d\u043e\u043c\u0443 \u043d\u0430\u0442\u0438\u0441\u043a\u0430\u043d\u043d\u0456 \u043a\u043b\u0430\u0432\u0456\u0448\u0456."],"Search on submit only":["\u041f\u043e\u0448\u0443\u043a \u043b\u0438\u0448\u0435 \u043f\u0456\u0441\u043b\u044f \u043d\u0430\u0442\u0438\u0441\u043a\u0430\u043d\u043d\u044f \u043a\u043d\u043e\u043f\u043a\u0438 \u00ab\u0412\u0456\u0434\u043f\u0440\u0430\u0432\u0438\u0442\u0438\u00bb"],"Show search icon":["\u041f\u043e\u043a\u0430\u0437\u0430\u0442\u0438 \u0456\u043a\u043e\u043d\u043a\u0443 \u043f\u043e\u0448\u0443\u043a\u0443"],"Leave empty to use the default translated placeholder.":["\u0417\u0430\u043b\u0438\u0448\u0442\u0435 \u043f\u043e\u043b\u0435 \u043f\u043e\u0440\u043e\u0436\u043d\u0456\u043c, \u0449\u043e\u0431 \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u0432\u0430\u0442\u0438 \u043f\u0435\u0440\u0435\u043a\u043b\u0430\u0434\u0435\u043d\u0438\u0439 \u0437\u0430 \u0437\u0430\u043c\u043e\u0432\u0447\u0443\u0432\u0430\u043d\u043d\u044f\u043c \u0437\u0430\u043f\u043e\u0432\u043d\u044e\u0432\u0430\u0447."],"Placeholder":["\u0417\u0430\u043f\u043e\u0432\u043d\u044e\u0432\u0430\u0447"],"42 results":["42 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u0438"],"Leave empty to use the default translated label.":["\u0417\u0430\u043b\u0438\u0448\u0442\u0435 \u043f\u043e\u043b\u0435 \u043f\u043e\u0440\u043e\u0436\u043d\u0456\u043c, \u0449\u043e\u0431 \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u0432\u0430\u0442\u0438 \u043f\u0435\u0440\u0435\u043a\u043b\u0430\u0434\u0435\u043d\u0443 \u0437\u0430 \u0437\u0430\u043c\u043e\u0432\u0447\u0443\u0432\u0430\u043d\u043d\u044f\u043c \u043c\u0456\u0442\u043a\u0443."],"Button label":["\u041c\u0456\u0442\u043a\u0430 \u043a\u043d\u043e\u043f\u043a\u0438"],"Most recent first":["\u0421\u043f\u043e\u0447\u0430\u0442\u043a\u0443 \u043d\u0430\u0439\u043d\u043e\u0432\u0456\u0448\u0456"],"Leave empty to use the default \"Date\" label.":["\u0417\u0430\u043b\u0438\u0448\u0442\u0435 \u043f\u043e\u043b\u0435 \u043f\u043e\u0440\u043e\u0436\u043d\u0456\u043c, \u0449\u043e\u0431 \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u0432\u0430\u0442\u0438 \u043f\u043e\u0437\u043d\u0430\u0447\u043a\u0443 \"\u0414\u0430\u0442\u0430\" \u0437\u0430 \u0437\u0430\u043c\u043e\u0